{
  "expo": {
    "name": "Rafiki Games",
    "slug": "rafikischoolgamestracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/school-logo.png",
    "scheme": "rafikischoolgamestracker",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/school-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rafikischoolgamestracker.app"
    },
    "android": {
      "package": "com.rafikischoolgamestracker.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/school-logo.png",
        "backgroundColor": "#0D1117"
      }
    },
    "web": {
      "favicon": "./assets/images/school-logo.png",
      "output": "static",
      "bundler": "metro",
      "name": "Rafiki Games",
      "shortName": "Rafiki",
      "description": "Virtue point tracker for Rafiki Foundation school",
      "themeColor": "#0D1117",
      "backgroundColor": "#0D1117"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
